# Copy this to .env and fill in your values.
# These are substituted into docker-compose.yml at startup.

# The URL where Sempa is accessible (no trailing slash)
APP_URL=http://localhost:9001

# Host port to bind (the app always listens on 9001 internally)
HOST_PORT=9001

# Attachment blobs are stored on disk here (defaults to <db-dir>/attachments,
# i.e. inside the same Docker volume as the database, so they persist + are
# included in backups). Override only if you want them elsewhere.
# ATTACHMENTS_DIR=/data/attachments
