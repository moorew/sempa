# Copy this to .env.local and fill in your secrets.
# This file is loaded INTO the container — never commit it.

# ── Authentication ──────────────────────────────────────────────────────────
# Option A: Google Sign-In (recommended)
# See: https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Comma-separated emails allowed to log in. Leave blank to allow any Google account.
SEMPA_ALLOWED_EMAILS=you@gmail.com

# Option B: Username & password (fallback / alternative)
# SEMPA_USERNAME=admin
# SEMPA_PASSWORD=

# ── Tailscale ─────────────────────────────────────────────────────────────────
# Auth key for the Tailscale sidecar container (ts-sempa service)
# Generate at: https://login.tailscale.com/admin/settings/keys
# TS_AUTHKEY=tskey-auth-...

# ── Email → task (optional) ─────────────────────────────────────────────────
# Token for the Cloudflare Email Routing → task webhook.
# EMAIL_FORWARD_TOKEN=
# Restrict which senders can create tasks (comma-separated).
# Full email addresses or @domain suffixes. Empty = accept all.
# SMTP_ALLOWED_SENDERS=you@fastmail.com,@company.com

# ── Notifications (optional) ────────────────────────────────────────────────
# Web Push contact (RFC 8292 `sub`). The VAPID key pair auto-generates on first
# boot; this is just the contact address embedded in push JWTs.
# VAPID_SUBJECT=mailto:you@example.com
# Native Android push (FCM) — path to a Firebase service-account JSON key.
# FCM_KEY_PATH=/data/firebase-service-account.json

# ── AI task-title cleanup ───────────────────────────────────────────────────
# Runs on the bundled local model (the `ollama` service) — no API key required.
# Override the model if you like (default: qwen2.5:1.5b).
# OLLAMA_MODEL=qwen2.5:1.5b
